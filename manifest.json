{
  "manifest_version": 3,
  "name": "UKG Timesheet CSV Filler",
  "version": "1.0.0",
  "description": "Fills a UKG Pro Workforce Management timesheet from a CSV. Never submits — only fills empty rows.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.ultipro.com/*"
  ],
  "action": {
    "default_title": "Fill UKG timesheet from CSV",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
